// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String            @id @default(cuid())
  email                String            @unique
  name                 String
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  videos               Video[]
  comments             Comment[]
  workspaceMemberships WorkspaceMember[]
  emailVerified        Boolean           @default(false)
  image                String?
  sessions             Session[]
  accounts             Account[]
  ownedWorkspace       Workspace[]       @relation("WorkspaceOwner") //workspace i owned or the head of it.
  sentInvites          WorkspaceInvite[] @relation("SentInvites")
  receivedInvites      WorkspaceInvite[] @relation("ReceivedInvites")
}

model Video {
  id           String     @id @default(cuid())
  title        String
  description  String?
  s3key        String?
  videoUrl     String?
  thumbnailKey String?
  duration     Int?
  visibility   Visibility @default(PRIVATE)
  viewCount    Int        @default(0)
  fileSize     Int?

  shareId String @unique @default(cuid())

  processingStatus ProcessingStatus @default(UPLOADED)

  userId        String
  workspaceId   String?
  mimeType      String?
  recordingType RecordingType?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processingStartedAt DateTime?
  processingEndedAt   DateTime?
  errorMessage        String?

  owner User @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull) // if deleted video should not be

  comments    Comment[]
  transcript  Transcript?
  summary     Summary?
  actionItems ActionItem[]

  @@index([userId])
  @@index([workspaceId])
  @@index([processingStatus])
}

model Workspace {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  ownerId String

  owner User @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members WorkspaceMember[]
  videos  Video[]
  invites WorkspaceInvite[]

  @@index([ownerId]) // for getting all workspaces of the owner very fast.
}

model WorkspaceMember {
  id String @id @default(cuid())

  userId      String
  workspaceId String

  role WorkspaceRole

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model WorkspaceInvite {
  id String @id @default(cuid())

  workspaceId   String
  invitedUserId String
  invitedById   String

  role WorkspaceRole @default(MEMBER)

  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  invitedUser User @relation("ReceivedInvites", fields: [invitedUserId], references: [id], onDelete: Cascade)

  invitedBy User @relation("SentInvites", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([workspaceId, invitedUserId])
}


enum WorkspaceRole {
  OWNER
  MEMBER
}

enum Visibility {
  PRIVATE
  PUBLIC
  UNLISTED
}

enum ProcessingStatus {
  UPLOADED
  PROCESSING
  TRANSCRIBED
  COMPLETED
  FAILED
}

enum RecordingType {
  SCREEN
  CAMERA
  SCREEN_AND_CAMERA
}

model Comment {
  id String @id @default(cuid())

  content String

  timestamp Int?

  userId  String
  videoId String

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([userId])
}

model Transcript {
  id String @id @default(cuid())

  content String @db.Text

  videoId String @unique

  createdAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
}

model Summary {
  id String @id @default(cuid())

  content String @db.Text

  videoId String @unique

  createdAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
}

model ActionItem {
  id String @id @default(cuid())

  task String

  completed Boolean @default(false)

  videoId String

  createdAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}
